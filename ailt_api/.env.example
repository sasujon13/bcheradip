# XAMPP MySQL — copy to ailt_api/.env
HOST=0.0.0.0
PORT=8790

# Default XAMPP: user root, empty password, port 3306
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/ailanguagetutor?charset=utf8mb4

ADMIN_SEED_EMAIL=sashafik.me@gmail.com
ADMIN_SEED_WHATSAPP=+8801722710298
ADMIN_SEED_PASSWORD=change-me

TRIAL_DAYS=7
DEV_LOG_OTP=true

# SMTP — local dev only (see Android repo server/mail/run-dev-smtp.ps1)
SMTP_ENABLED=true
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=admin@ailanguagetutor.com
SMTP_USER=admin@ailanguagetutor.com
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false

PUBLIC_BASE_URL=http://localhost:8790/api/ailt
# Linux production (bcheradip nginx):
# PUBLIC_BASE_URL=https://cheradip.com/ailt/api
# Legacy PC tunnel (deprecated after Linux cutover):
# PUBLIC_BASE_URL=https://ailt.cheradip.com/api/ailt

# Optional cloud AI keys (fallback when home AI times out)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Anthropic Haiku 3.5 retired Feb 2026 — use Haiku 4.5:
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_PAID_MODEL=claude-sonnet-4-5-20250929
# OpenRouter free pool (auto-picks an available free model):
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_PAID_MODEL=anthropic/claude-3.5-sonnet

# Response translation (skip admin/promo/referral paths; 4s timeout if Home AI down)
# TRANSLATE_API_RESPONSES=true
# TRANSLATE_API_TIMEOUT_SECONDS=4
# HOME_AI_TRANSLATE_URL=http://127.0.0.1:8787/translate-strings
