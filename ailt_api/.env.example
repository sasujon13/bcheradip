# XAMPP MySQL — copy to ailt_api/.env
HOST=0.0.0.0
PORT=8790

# Default XAMPP: user root, empty password, port 3306
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/ailanguagetutor?charset=utf8mb4
# Separate database for the Cheradip VS Code extension (users, billing, credits, payments)
EXT_DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/extcheradip?charset=utf8mb4

ADMIN_SEED_EMAIL=sashafik.me@gmail.com
ADMIN_SEED_WHATSAPP=+8801722710298
ADMIN_SEED_PASSWORD=change-me

# Cheradip extension admin (separate ext_users space).
# Leave blank to reuse ADMIN_SEED_EMAIL / ADMIN_SEED_PASSWORD above.
EXT_ADMIN_SEED_EMAIL=
EXT_ADMIN_SEED_PASSWORD=

TRIAL_DAYS=7
GUEST_AI_LIMIT=99999999
DEV_LOG_OTP=true

# SMTP — local dev: fake SMTP on 1025 (see Android repo server/mail/run-dev-smtp.ps1)
# Production (Linux): Brevo only — deploy/BREVO_EMAIL.md
SMTP_ENABLED=true
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=admin@ailanguagetutor.com
SMTP_USER=admin@ailanguagetutor.com
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false

PUBLIC_BASE_URL=http://localhost:8790/api/ailt
# Linux production (bcheradip nginx):
# PUBLIC_BASE_URL=https://cheradip.com/ailt/api
# Legacy PC tunnel (deprecated after Linux cutover):
# PUBLIC_BASE_URL=https://ailt.cheradip.com/api/ailt

# Google Play Billing (AI Language Tutor Android app) — server-side purchase
# verification. Create a service account in Google Cloud, grant it access in
# Play Console (Users & permissions → "View financial data, orders, and
# cancellation survey responses"), then paste the JSON path or inline JSON.
# Leave blank ONLY for local dev (verify trusts the client — never in prod).
GOOGLE_PLAY_PACKAGE_NAME=com.cheradip.ailanguagetutor
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# Shared secret appended as ?token=... to the RTDN Pub/Sub push URL:
#   https://cheradip.com/ailt/api/billing/rtdn?token=YOUR_SECRET
GOOGLE_PLAY_RTDN_TOKEN=

# Optional cloud AI keys (fallback when home AI times out)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Intent-based model overrides (optional — defaults in config.py):
# GEMINI_MODEL_FAST=gemini-flash-lite-latest
# GEMINI_MODEL_CODING=gemini-2.5-flash
# GEMINI_MODEL_COMPLEX=gemini-2.5-pro
# OPENAI_MODEL_DEFAULT=gpt-4o-mini
# OPENAI_PAID_MODEL_CODING=o4-mini
# GROQ_MODEL_CODING=qwen/qwen3-32b
# GROQ_MODEL_COMPLEX=llama-3.3-70b-versatile
# ANTHROPIC_MODEL=claude-haiku-4-5
# ANTHROPIC_PAID_MODEL=claude-sonnet-4-5
# MISTRAL_MODEL_CODING=codestral-latest
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_MODEL_CODING=qwen/qwen3-coder:free

# Cheradip VS Code extension billing.
# Provider: "paddle" (Merchant of Record — works from Bangladesh, pays out by
# wire/Payoneer; charges cards worldwide and remits tax) or "stripe".
# Leave provider keys blank to disable checkout (license-key activation + usage
# tracking still work; checkout falls back to the pricing page).
BILLING_PROVIDER=paddle
BILLING_SUCCESS_URL=https://cheradip.com/ailt/billing/success
BILLING_CANCEL_URL=https://cheradip.com/ailt/billing/cancel
BILLING_PRICING_URL=https://cheradip.com/ailt/pricing

# Paddle Billing for the Cheradip coding extension (create prices in Paddle, paste ids)
# The AI Language Tutor app uses Google Play Billing, not Paddle.
# NOTE: these are only .env fallbacks/bootstrap. The admin can set them at runtime
# from https://cheradip.com/ailt/paddle (stored in app_settings; DB overrides .env).
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CLIENT_TOKEN=
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_PRO=
PADDLE_PRICE_PLUS=
PADDLE_PRICE_BUSINESS=

# Stripe (optional fallback; not usable from Bangladesh)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_BUSINESS=

# Response translation (skip admin/promo/referral paths; 4s timeout if Home AI down)
# TRANSLATE_API_RESPONSES=true
# TRANSLATE_API_TIMEOUT_SECONDS=4
# HOME_AI_TRANSLATE_URL=http://127.0.0.1:8787/translate-strings
