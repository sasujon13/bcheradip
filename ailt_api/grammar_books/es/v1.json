      "title": "Verbos — presente",
      "summary": "Presente de indicativo.",
      "sections": [
        {
          "heading": "Presente",
          "body": "Tres conjugaciones: -ar, -er, -ir. Ser y estar son esenciales.",
          "examples": [
            "Yo hablo.",
            "Ella come.",
            "Estamos aquí."
          ],
          "learnerTip": ""
        }
      ]
