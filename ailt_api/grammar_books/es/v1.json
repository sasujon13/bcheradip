      "summary": "Género, número y artículos.",
      "sections": [
        {
          "heading": "Artículos",
          "body": "un/una, el/la, los/las. El género es masculino o femenino.",
          "examples": [
            "un libro",
            "la casa",
            "los niños"
          ],
          "learnerTip": ""
        }
      ]
