      "title": "Preguntas y negación",
      "summary": "Preguntar y negar.",
      "sections": [
        {
          "heading": "Negación",
          "body": "no + verbo: No entiendo.",
          "examples": [
            "No sé.",
            "No está aquí."
          ],
          "learnerTip": ""
        }
      ]
    },
