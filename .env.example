# ==============================================================================
# CHERADIP BACKEND CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your values

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DATABASE_NAME=cheradip_cheradip
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=3306

# CORS Settings
CORS_ORIGIN_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
# CSRF (Angular dev server → Django API POST)
CSRF_TRUSTED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
HOST_URL=http://127.0.0.1:8000

# ==============================================================================
# EMAIL CONFIGURATION (FREE via Gmail) - PRIMARY VERIFICATION METHOD
# ==============================================================================
# 
# Setup Steps:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Go to: Google Account > Security > App Passwords
# 3. Create new App Password for "Mail"
# 4. Copy the 16-character password here
#
# Free Limit: 500 emails/day

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_16_char_app_password
DEFAULT_FROM_EMAIL=Cheradip <your_email@gmail.com>

# ==============================================================================
# WHATSAPP VERIFICATION (FREE via CallMeBot) - FALLBACK METHOD
# ==============================================================================
#
# This is the fallback when users don't have an email address.
# CallMeBot provides FREE WhatsApp messaging!
#
# HOW USERS ACTIVATE (One-time setup for each user):
# 1. Add +34 644 51 95 23 to their WhatsApp contacts
# 2. Send this message via WhatsApp: "I allow callmebot to send me messages"
# 3. They receive an API key in the response
# 4. Save the API key in their Cheradip profile settings
#
# No server configuration needed - users manage their own activation.
# The API key is stored per-user in the database (whatsapp_apikey field)

# ==============================================================================
# GOOGLE CLOUD TRANSLATION (optional – for translating website to country language)
# ==============================================================================
# When set, API responses are translated to the language from the selected country.
# Get an API key: https://console.cloud.google.com/apis/credentials
# Enable "Cloud Translation API" for your project.
# Leave empty to skip translation (content shown in original language).
GOOGLE_TRANSLATE_API_KEY=
