# Copy to .env.db-sync in this folder (gitignored). Used by: python manage.py mysql_db_sync
#
# IMPORTANT: cheradip.com is behind Cloudflare — MySQL/SSH cannot connect to that hostname.
# Use your Linux server's real IP for SSH_HOST (from hosting panel / VPS dashboard).

# --- SSH tunnel (recommended) ---
SSH_TUNNEL=1
SSH_HOST=YOUR_SERVER_IP
SSH_USER=sasha
SSH_PASSWORD=your_ssh_password
SSH_PORT=22
SSH_LOCAL_PORT=13306
SSH_REMOTE_MYSQL_HOST=127.0.0.1
SSH_REMOTE_MYSQL_PORT=3306

# --- MySQL on the remote Linux server (via tunnel → 127.0.0.1 below) ---
REMOTE_HOST=127.0.0.1
REMOTE_PORT=13306
REMOTE_USER=cheradip_cheradip
REMOTE_PASSWORD=your_mysql_password

# --- Local XAMPP ---
LOCAL_HOST=127.0.0.1
LOCAL_PORT=3306
LOCAL_USER=root
LOCAL_PASSWORD=

# Optional: only sync one DB (if remote user lacks CREATE DATABASE on others)
# SYNC_DATABASES=cheradip_cheradip
