# Copy to .env and fill in secrets. Used when hosting cheradip.com from your server.
# NEVER commit real .env to git.

DEBUG=False
SECRET_KEY=change-me-to-a-long-random-string

ALLOWED_HOSTS=cheradip.com,www.cheradip.com,localhost,127.0.0.1

CORS_ORIGIN_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=https://cheradip.com,https://www.cheradip.com

HOST_URL=https://cheradip.com

DATABASE_NAME=cheradip_cheradip
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_HOST=localhost
DATABASE_PORT=3306
